{
  "type": "module",
  "scripts": {
    "test": "node test/run-all.js",
    "test:patterns": "node test/patterns/library.test.js",
    "test:rules": "node test/rules/ruleset.test.js",
       "test:neighborhoods": "node test/rules/neighborhoods.test.js",
      "test:exotic": "node test/rules/exoticEngines.test.js",
    "test:simulation": "node test/patterns/simulation.test.js",
    "test:sim-engine": "node test/sim/simulation.test.js",
    "test:grid": "node test/grid.test.js",
     "test:topology": "node test/topology.test.js",
    "test:parsers": "node test/patterns/parsers.test.js",
    "test:infer": "node test/patterns/inferMetadata.test.js",
    "test:all": "node test/run-all.js",
    "import:lifewiki": "node src/patterns/lifewikiImporter.js --input /home/andrew/Downloads/all --output src/patterns/lifewiki.generated.json --verbose",
    "serve": "npx http-server -p 8080 -c-1",
    "lint": "eslint 'src/**/*.js' 'test/**/*.js'",
    "lint:fix": "eslint --fix 'src/**/*.js' 'test/**/*.js'",
    "format": "prettier --write 'src/**/*.js' 'test/**/*.js' '*.html' '*.css' '*.md'",
    "format:json": "prettier --write 'src/**/*.json'",
    "format:check": "prettier --check 'src/**/*.js' 'test/**/*.js' '*.html' '*.css' '*.md'",
    "validate": "npm run lint && npm run format:check && npm run test"
