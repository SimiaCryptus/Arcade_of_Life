       "label": "Missile Defender — wave in progress on desktop"
     },
     {
       "src": "/screenshot/level_designer.png",
       "sizes": "1280x800",
       "type": "image/png",
       "form_factor": "wide",
       "label": "Level Designer — build and share custom levels"
     },
     {
       "src": "/screenshot/pattern_zoo.png",
       "sizes": "1280x800",
       "type": "image/png",
       "form_factor": "wide",
       "label": "Pattern Zoo — browse hundreds of LifeWiki patterns"
    }
   ],
   "shortcuts": [
     {
       "name": "Missile Defender",
       "short_name": "Defender",
       "description": "Jump straight into Missile Defender — protect your cities from incoming gliders",
       "url": "/?mode=missile_defender",
       "icons": [
         {
           "src": "/icons/shortcut-defender.png",
           "sizes": "96x96",
           "type": "image/png"
         }
       ]
     },
     {
       "name": "Space Invaders",
       "short_name": "Invaders",
       "description": "Launch Space Invaders mode — shoot down descending spaceships",
       "url": "/?mode=space_invaders",
       "icons": [
         {
           "src": "/icons/shortcut-invaders.png",
           "sizes": "96x96",
           "type": "image/png"
         }
       ]
     },
     {
       "name": "Tower Defense",
       "short_name": "Tower",
       "description": "Open Tower Defense Simulator — place barriers before the simulation starts",
       "url": "/?mode=tower_defense",
       "icons": [
         {
           "src": "/icons/shortcut-tower.png",
           "sizes": "96x96",
           "type": "image/png"
         }
       ]
     },
     {
       "name": "Level Designer",
       "short_name": "Designer",
       "description": "Open the Level Designer and build a custom level",
       "url": "/?tool=level_designer",
       "icons": [
         {
           "src": "/icons/shortcut-designer.png",
           "sizes": "96x96",
           "type": "image/png"
         }
       ]
     }
   ],
   "share_target": {
     "action": "/share-target",
     "method": "POST",
     "enctype": "multipart/form-data",
     "params": {
       "title": "title",
       "text": "text",
       "url": "url",
       "files": [
         {
           "name": "level",
           "accept": ["application/json", ".json"]
         },
         {
           "name": "pattern",
           "accept": ["text/plain", ".rle", ".cells", ".lif"]
         }
       ]
     }
   },
   "file_handlers": [
     {
       "action": "/open-level",
       "accept": {
         "application/json": [".json"]
       },
       "icons": [
         {
           "src": "/icons/filetype-level.png",
           "sizes": "256x256",
           "type": "image/png"
         }
       ],
       "launch_type": "single-client"
     },
     {
       "action": "/open-pattern",
       "accept": {
         "text/plain": [".rle", ".cells", ".lif"]
       },
       "icons": [
         {
           "src": "/icons/filetype-pattern.png",
           "sizes": "256x256",
           "type": "image/png"
         }
       ],
       "launch_type": "single-client"
     }
   ],
   "protocol_handlers": [
     {
       "protocol": "web+arcadeoflife",
       "url": "/?protocol=%s"
     }
   ],
   "edge_side_panel": {
     "preferred_width": 480
   },
   "handle_links": "preferred",
   "launch_handler": {
     "client_mode": ["navigate-existing", "auto"]
   },
   "prefer_related_applications": false,
   "related_applications": [
     {
       "platform": "webapp",
       "url": "https://aol.cognotik.com/manifest.json",
       "id": "com.cognotik.arcadeoflife"
     }
   ]
}